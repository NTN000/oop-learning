# 4. Thực hiện các giao dịch liên tục cho từng tài khoản
print(20*"-")
print("\nBẮT ĐẦU THỰC HIỆN GIAO DỊCH:")

for tai_khoan in danh_sach_tai_khoan:
    print(f"\n--- Đang làm việc với tài khoản: {tai_khoan.tenTK} ---")
    
    # Thêm vòng lặp while True ở đây để thực hiện nhiều giao dịch trên 1 tài khoản
    while True:
        print(f"\nSố dư hiện tại của {tai_khoan.tenTK}: {tai_khoan.soDu}")
        action = input("Chọn: (n) Nạp tiền, (r) Rút tiền, (q) Xong/Chuyển tài khoản khác: ")
        
        if action.lower() == 'q':
            print(f"Kết thúc giao dịch với {tai_khoan.tenTK}.")
            break # Thoát vòng lặp while để chuyển sang tài khoản tiếp theo trong vòng for
            
        elif action.lower() == 'n':
            soTien = float(input("Nhập số tiền muốn nạp: "))
            tai_khoan.NapTien(soTien)
            
        elif action.lower() == 'r':
            soTien = float(input("Nhập số tiền muốn rút: "))
            tai_khoan.RutTien(soTien)
            
        else:
            print("Lựa chọn không hợp lệ. Vui lòng chọn 'n', 'r' hoặc 'q'.")

print("\n--- TẤT CẢ GIAO DỊCH ĐÃ HOÀN TẤT ---")