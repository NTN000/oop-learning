
#1. Đingh nghĩa lớp Tài khoản ngân hàng
class TaiKhoan:
    def __init__(self, tenTK, soTK, NganHang, soDu):
        self.tenTK = tenTK
        self.soTk = soTK
        self.NganHang = NganHang
        self.soDu = soDu

#2. Các phương thức
    def NapTien(self, soTien):
        self.soDu += soTien
        print(f" {self.tenTK} đã nạp {soTien} vào tài khoản. Số dư hiện tại: {self.soDu}")
    def RutTien(self, soTien):
        if soTien > self.soDu:
            print(f"{self.tenTK} không đủ tiền để rút. Số dư hiện tại: {self.soDu}")
        else:
            self.soDu -= soTien
            print(f"{ self.tenTK} đã rút {soTien} từ tài khoản. Số dư hiện tại: {self.soDu}")

#3. Tạo đối tượng tài khoản ngân hàng
danh_sach_tai_khoan = []
while True:
    tenTK = input("Nhập tên tài khoản (hoặc 'exit' để dừng): ")
    if tenTK.lower() == 'exit':
        break
    soTK = input("Nhập số tài khoản: ")
    NganHang = input("Nhập tên ngân hàng: ")
    soDu = float(input("Nhập số dư ban đầu: "))
    
    tai_khoan = TaiKhoan(tenTK, soTK, NganHang, soDu)
    danh_sach_tai_khoan.append(tai_khoan)

#4. Thực hiện các giao dịch
